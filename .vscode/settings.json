{
  "files.exclude": {
    "**/.next": true,
    "**/.turbo": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/out/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/out": true
  },
  "tailwindCSS.lint.suggestCanonicalClasses": "ignore",
  "tailwindCSS.files.exclude": [
    "**/.next/**",
    "**/node_modules/**"
  ],
  "npm.autoDetect": "off",
  "typescript.disableAutomaticTypeAcquisition": true
}